<!DOCTYPE html>
<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@300..900&display=swap" rel="stylesheet">
    <link rel="icon" href="/assets/favico.png">
    <link rel="stylesheet" href="/styles/base.css"/>
    <link rel="stylesheet" href="/styles/signup.css"/>
    <title>Uniflow</title>
  </head>
  <body>
    <div class="cover">
      <img src="/assets/favico.png">
      <span class="title">Uniflow</span>
      <span class="tagline">Autonomous AI agent. Human-guided flow.</span>
    </div> 
    <div class="container">
      <span id="title">Sign Up</span>
      <div class="form-container">
        <input required id="form-idNumber-input" type="text" placeholder="ID number">
        <input required id="form-fullName-input" type="text" placeholder="Full Legal Name">
        <input required id="form-password-input" type="password" placeholder="Password">
      </div>
      <div id="userType-container">
        <span class="label">I'm a...</span>
        <div id="form-userType-student" class="form-userType-option" data-value="student">Student</div>
        <div id="form-userType-faculty" class="form-userType-option" data-value="faculty">Faculty</div>
      </div>
      <button id="createAccount-button">Create account</button>
      <span id="subtext-login" class="subtext">Already have an account? <span id="subtext-login-redirect">Log In</span></span>
    </div>
    <script type="module" src="/scripts/signup.js"></script>
  </body>
</html>