<!DOCTYPE html>
<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@300..900&display=swap" rel="stylesheet">
    <link rel="icon" href="/assets/favico.png">
    <link rel="stylesheet" href="/styles/base.css"/>
    <link rel="stylesheet" href="/styles/login.css"/>
    <title>Uniflow</title>
  </head>
  <body>
    <div class="cover">
      <img src="/assets/favico.png">
      <span class="title">Uniflow</span>
      <span class="tagline">Autonomous AI agent. Human-guided flow.</span>
    </div> 
    <div class="container">
      <span id="title">Log In</span>
      <div class="form-container">
        <input required id="form-idNumber-input" placeholder="ID Number" type="text">
        <input required id="form-password-input" placeholder="password" type="password">
      </div>
      <span class="subtext" id="forgotPassword">Forgot Password?</span>
      <button id="login-button">Log In</button>
      <span class="subtext" id="subtext-createAccount">Don't have an account? <span id="subtext-createAccount-redirect">Create one!</span></span>
    </div>
    <script type="module" src="/scripts/login.js"></script>
  </body>
</html>