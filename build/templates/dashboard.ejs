<!DOCTYPE html>
<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@300..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles/base.css"/>
    <link rel="stylesheet" href="/styles/dashboard.css"/>
    <title>QuickSend</title>
  </head>
  <body>
    <header>
      <span id="dashboard-title">QuickSend</span>
    </header>
    <main>
      <section id="sidePanel">
        <div class="navigator">Dashboard</div>
        <div class="navigator">Workflows</div>
        <div class="navigator">History</div>
      </section>
      <section id="content">
        <div id="workflows-container">
          <div class="workflow">
            <img class="workflow-icon">
            <span class="workflow-name">Workflow Name Placeholder</span>
            <span class="workflow-subtext">Workflow Description Placeholder</span>
          </div>
        </div>
        <div id="historyOverview">
          <div class="workflowInstanceOverview">
            <img class="workflow-icon">
            <span class="workflow-name">Workflow Name Placeholder</span>
            <span class="workflow-status">Workflow Status Placeholder</span>
            <div class="workflow-options">
              <div id="workflow-options-edit" class="workflow-option">Edit</div>
              <div id="workflow-options-rerun" class="workflow-option">Rerun</div>
              <div id="workflow-options-delete" class="workflow-option">Delete</div>
            </div>
          </div>
        </div>
      </section>
    </main>
    <script type="module" src="/scripts/dashboard.js"></script>
  </body>
</html>