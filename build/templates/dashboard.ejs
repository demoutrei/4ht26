<!DOCTYPE html>
<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@300..900&display=swap" rel="stylesheet">
    <link rel="icon" href="/assets/favico.png">
    <link rel="stylesheet" href="/styles/base.css"/>
    <link rel="stylesheet" href="/styles/dashboard.css"/>
    <title>Uniflow</title>
  </head>
  <body>
    <header>
      <span id="dashboard-title">Uniflow</span>
    </header>
    <main>
      <!-- <section id="sidePanel">
        <div class="navigator">Dashboard</div>
        <div id="navigator-workflows" class="navigator">Workflows</div>
        <div id="navigator-history" class="navigator">History</div>
      </section> -->
      <section id="content">
        <span class="heading">Workflows</span>
        <div id="workflows-container">
          <div class="workflowTemplate" data-workflow-id="1">
            <img class="workflow-icon">
            <span class="workflow-name">Booking</span>
            <span class="workflow-subtext">Book for a reservation</span>
            <button class="workflow-editButton">Edit</button>
          </div>
        </div>
        <span class="heading">History</span>
        <div id="historyOverview">
          <% instances.forEach(instance => { %>
            <div class="workflowInstanceOverview">
              <img class="workflow-icon">
              <span class="workflow-name">Booking</span>
              <span class="workflow-status">Pending</span>
              <div class="workflow-options show">
              <div id="workflow-options-edit" class="workflow-option">Edit</div>
              <div id="workflow-options-rerun" class="workflow-option">Rerun</div>
              <div id="workflow-options-delete" class="workflow-option">Delete</div>
            </div>
            </div>
          <% }); %>
        </div>
      </section>
    </main>
    <script type="module" src="/scripts/dashboard.js"></script>
  </body>
</html>